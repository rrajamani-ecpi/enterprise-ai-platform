{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "PlatformAuthentication": {
    "Mode": "Entra"
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "REPLACE_WITH_TENANT_ID",
    "ClientId": "REPLACE_WITH_CLIENT_ID",
    "CallbackPath": "/signin-oidc",
    "SignedOutCallbackPath": "/signout-callback-oidc"
  },
  "RoleDerivation": {
    "Mappings": [
      { "GroupId": "00000000-0000-0000-0000-000000000001", "Role": "Admin" },
      { "GroupId": "00000000-0000-0000-0000-000000000002", "Role": "Employee" },
      { "GroupId": "00000000-0000-0000-0000-000000000003", "Role": "Student" }
    ]
  },
  "PublicRoutes": {
    "Paths": [
      "/health/live",
      "/health/ready",
      "/MicrosoftIdentity/Account/SignIn",
      "/signin-oidc",
      "/signout-callback-oidc"
    ]
  },
  "Cosmos": {
    "AccountEndpoint": "",
    "DatabaseName": "eap",
    "UserContainerName": "users"
  }
}
